---
const sections = [
  {
    heading: "Computer Science Courses",
    items: [
      "Introduction to Computer Science",
      "Discrete Structures",
      "Elements of Game Design",
      "Data Structures",
      "Computer Architecture",
      "Systems Programming",
      "Programming Studio",
      "Introduction to Algorithms & Models of Computation",
      "Programming Languages and Compilers",
    ],
  },
  {
    heading: "Linguistics Courses",
    items: [
      "Introduction to Language Science",
      "Language, Mind and Brain",
      "Elements of Syntax",
      "Elements of Phonology",
      "Elements of Semantics & Pragmatics",
      "Language Processing",
      "Introduction to Computational Lingustics",
      "Computational Morphology",
      "Corpus Linguistics",
    ],
  },
  {
    heading: "Other Courses",
    items: [
      "Statistics",
      "Calculus II & III",
      "Introductory Matrix Theory",
      "Elementary Japanese I, II, III & IV",
      "Accessible Electronic Material",
      "Designing Accessible Web Resources",
      "Disability & Assistive Technology",
      "Marching Illini",
    ],
  },
];

const programWebsiteUrl =
  "https://siebelschool.illinois.edu/academics/undergraduate/degree-program-options/cs-x-degree-programs/computer-science-linguistics";

const iadpCourses = [
  "Accessible Electronic Material",
  "Designing Accessible Web Resources",
  "Disability & Assistive Technology",
];

const iadpSection = {
  heading: "Courses",
  items: iadpCourses,
};

const iadpProgramWebsiteUrl = "https://iadp.ahs.illinois.edu/program/details/";

const slugify = (value) => value.toLowerCase().replaceAll(" ", "-");

const sectionLinks = [
  { label: "Degree", href: "#degree" },
  { label: "Curriculum", href: "#curriculum" },
  {
    label: "Information Accessibility Design and Policy",
    href: "#iadp",
  },
];
---

<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>
      B.S. Computer Science + Lingustics
    </title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        savedTheme ?? (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <nav class="section-sidebar" aria-label="Page sections">
      <div class="drawer-controls">
        <a
          class="home-link"
          href="/"
          aria-label="Go home"
          title="Home"
        >
          <img
            class="home-link-icon"
            src="/icons/home.png"
            alt=""
            aria-hidden="true"
          />
        </a>
        <!--
          Theme icons created by dokodemo - Flaticon
          https://www.flaticon.com/free-icons/theme
        -->
        <button
          class="theme-toggle"
          type="button"
          aria-label="Switch to dark mode"
          title="To Dark Mode"
        >
          <img
            class="theme-toggle-icon"
            src="/icons/light-to-dark.png"
            alt=""
            aria-hidden="true"
          />
        </button>
      </div>
      {
        sectionLinks.map((link) => (
          <a href={link.href} data-section-link={link.href.slice(1)}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <button
      class="nav-backdrop"
      type="button"
      aria-label="Close section navigation"
    >
    </button>

    <main class="site-shell">
      <div class="page-controls">
        <button
          class="nav-toggle"
          type="button"
          aria-label="Open section navigation"
          aria-expanded="false"
        >
          <img
            class="nav-toggle-icon"
            src="/icons/list.png"
            alt=""
            aria-hidden="true"
          />
        </button>
        <div class="page-control-links desktop-controls">
          <a
            class="home-link"
            href="/"
            aria-label="Go home"
            title="Home"
          >
            <img
              class="home-link-icon"
              src="/icons/home.png"
              alt=""
              aria-hidden="true"
            />
          </a>
          <!--
            Theme icons created by dokodemo - Flaticon
            https://www.flaticon.com/free-icons/theme
          -->
          <button
            class="theme-toggle"
            type="button"
            aria-label="Switch to dark mode"
            title="To Dark Mode"
          >
            <img
              class="theme-toggle-icon"
              src="/icons/light-to-dark.png"
              alt=""
              aria-hidden="true"
            />
          </button>
        </div>
      </div>

      <header class="certificate-hero" id="degree">
        <img
          class="certificate-icon"
          src="/resume-icons/illinois.jpeg"
          alt="University of Illinois Urbana-Champaign logo"
        />
        <div class="certificate-copy">
          <div class="certificate-heading">
            <p class="eyebrow">
              Bachelor of Science (B.S.)
            </p>
            <h1>
              Computer Science + Lingustics
            </h1>
          </div>
          <p class="intro">
            An interdisciplinary University of Illinois degree combining computing,
            language science, and the study of natural language technologies.
          </p>
          <div class="program-links">
            <a
              class="program-link"
              href={programWebsiteUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Program Website
            </a>
            <a class="program-link" href="#iadp">
              <span class="program-label-full">
                Information Accessibility Design and Policy
              </span>
              <span class="program-label-short">
                IADP
              </span>
            </a>
            <a class="program-link" href="/illinois-diploma.pdf">
              Diploma
            </a>
          </div>
        </div>
      </header>

      <section class="section" id="curriculum" aria-labelledby="curriculum-heading">
        <h2 id="curriculum-heading">
          Curriculum
        </h2>
        <div class="curriculum-chart">
          {
            sections.map((section) => (
              <section
                class="course-group"
                id={slugify(section.heading)}
                aria-labelledby={`${section.heading.toLowerCase().replaceAll(" ", "-")}-heading`}
              >
                <h3
                  id={`${section.heading.toLowerCase().replaceAll(" ", "-")}-heading`}
                >
                  {section.heading}
                </h3>
                <ul>
                  {section.items.map((item) => (
                    <li>
                      {item}
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <section
        class="section certificate-program"
        id="iadp"
        aria-labelledby="iadp-heading"
      >
        <div class="certificate-overview">
          <img
            class="certificate-icon"
            src="/resume-icons/illinois-ahs.jpeg"
            alt="University of Illinois College of Applied Health Sciences logo"
          />
          <div class="certificate-copy">
            <div class="certificate-heading">
              <p class="eyebrow">
                Professional Certificate
              </p>
              <h2 id="iadp-heading">
                Information Accessibility Design and Policy
              </h2>
            </div>
            <p class="intro">
              A University of Illinois College of Applied Health Sciences certificate
              focused on accessible information architecture, assistive technology,
              universal design, and inclusive digital resources.
            </p>
            <a
              class="program-link"
              href={iadpProgramWebsiteUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Program Website
            </a>
          </div>
        </div>
        <h3 class="overview-heading">
          Overview
        </h3>
        <div class="curriculum-chart">
          <section class="course-group course-group-wide">
            <h3>
              {iadpSection.heading}
            </h3>
            <ul>
              {iadpSection.items.map((item) => (
                <li>
                  {item}
                </li>
              ))}
            </ul>
          </section>
        </div>
      </section>

      <footer class="page-footer">
        <a
          class="top-link"
          href="#degree"
          aria-label="Go to top of page"
          title="Top"
        >
          Top of Page
        </a>
      </footer>
    </main>
    <script>
      /** @typedef {"light" | "dark"} Theme */
      const themeToggles =
        document.querySelectorAll<HTMLButtonElement>(".theme-toggle");
      const themeToggleIcons =
        document.querySelectorAll<HTMLImageElement>(".theme-toggle-icon");
      const navToggle =
        document.querySelector<HTMLButtonElement>(".nav-toggle");
      const sectionSidebar = document.querySelector(".section-sidebar");
      const navBackdrop =
        document.querySelector<HTMLButtonElement>(".nav-backdrop");
      const pageSections = document.querySelectorAll(
        ".certificate-hero[id], .section[id]",
      );
      const sectionMapLinks = document.querySelectorAll("[data-section-link]");
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

      /**
       * @param {Theme} theme
       * @param {boolean} persist
       */
      function setTheme(theme, persist = true) {
        document.documentElement.dataset.theme = theme;
        if (persist) {
          localStorage.setItem("theme", theme);
        }

        themeToggles.forEach((themeToggle) => {
          themeToggle.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light mode" : "Switch to dark mode",
          );
          themeToggle.setAttribute(
            "title",
            theme === "dark" ? "To Light Mode" : "To Dark Mode",
          );
        });

        themeToggleIcons.forEach((themeToggleIcon) => {
          themeToggleIcon.src =
            theme === "dark" ? "/icons/dark-to-light.png" : "/icons/light-to-dark.png";
        });
      }

      const currentTheme =
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setTheme(currentTheme, false);

      systemTheme.addEventListener("change", (event) => {
        if (!localStorage.getItem("theme")) {
          setTheme(event.matches ? "dark" : "light", false);
        }
      });

      themeToggles.forEach((themeToggle) => {
        themeToggle.addEventListener("click", () => {
          setTheme(
            document.documentElement.dataset.theme === "dark" ? "light" : "dark",
          );
        });
      });

      const closeSectionNavigation = () => {
        sectionSidebar?.classList.remove("is-open");
        navBackdrop?.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      };

      navToggle?.addEventListener("click", () => {
        const isOpen = !sectionSidebar?.classList.contains("is-open");
        sectionSidebar?.classList.toggle("is-open", isOpen);
        navBackdrop?.classList.toggle("is-open", isOpen);
        navToggle.setAttribute("aria-expanded", String(isOpen));
      });

      navBackdrop?.addEventListener("click", closeSectionNavigation);

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSectionNavigation();
        }
      });

      const carouselCharts =
        document.querySelectorAll<HTMLElement>(".curriculum-chart");
      const mobileView = window.matchMedia("(max-width: 760px)");

      carouselCharts.forEach((chart) => {
        const cards = Array.from(chart.querySelectorAll<HTMLElement>(".course-group"));

        if (!mobileView.matches) {
          return;
        }

        if (cards.length <= 1 || chart.nextElementSibling?.classList.contains("carousel-scrubber")) {
          return;
        }

        const scrubber = document.createElement("div");
        scrubber.className = "carousel-scrubber";
        scrubber.setAttribute("aria-hidden", "true");

        const scrubberThumb = document.createElement("button");
        scrubberThumb.type = "button";
        scrubber.append(scrubberThumb);

        const updateCarouselControls = () => {
          const maxScroll = chart.scrollWidth - chart.clientWidth;
          const scrubberWidth = scrubber.clientWidth;
          const thumbWidth = Math.max(
            28,
            (chart.clientWidth / chart.scrollWidth) * scrubberWidth,
          );
          const maxThumbOffset = scrubberWidth - thumbWidth;
          const progress = maxScroll > 0 ? chart.scrollLeft / maxScroll : 0;

          scrubberThumb.style.width = `${thumbWidth}px`;
          scrubberThumb.style.transform = `translateX(${progress * maxThumbOffset}px)`;
        };

        let isChartDragging = false;
        let chartDragStartX = 0;
        let chartDragStartScroll = 0;

        chart.addEventListener("pointerdown", (event) => {
          if (event.pointerType === "mouse" && event.button !== 0) {
            return;
          }

          isChartDragging = true;
          chartDragStartX = event.clientX;
          chartDragStartScroll = chart.scrollLeft;
          chart.classList.add("is-dragging");
          chart.setPointerCapture(event.pointerId);
        });

        chart.addEventListener("pointermove", (event) => {
          if (!isChartDragging) {
            return;
          }

          chart.scrollLeft = chartDragStartScroll - (event.clientX - chartDragStartX);
        });

        const stopChartDrag = (event) => {
          isChartDragging = false;
          chart.classList.remove("is-dragging");
          if (chart.hasPointerCapture(event.pointerId)) {
            chart.releasePointerCapture(event.pointerId);
          }
        };

        chart.addEventListener("pointerup", stopChartDrag);
        chart.addEventListener("pointercancel", stopChartDrag);

        let isScrubberDragging = false;

        const moveScrubber = (event) => {
          const rect = scrubber.getBoundingClientRect();
          const progress = Math.min(
            1,
            Math.max(0, (event.clientX - rect.left) / rect.width),
          );

          chart.scrollLeft = progress * (chart.scrollWidth - chart.clientWidth);
        };

        scrubber.addEventListener("pointerdown", (event) => {
          isScrubberDragging = true;
          scrubber.setPointerCapture(event.pointerId);
          moveScrubber(event);
        });

        scrubber.addEventListener("pointermove", (event) => {
          if (isScrubberDragging) {
            moveScrubber(event);
          }
        });

        scrubber.addEventListener("pointerup", (event) => {
          isScrubberDragging = false;
          if (scrubber.hasPointerCapture(event.pointerId)) {
            scrubber.releasePointerCapture(event.pointerId);
          }
        });

        chart.after(scrubber);
        chart.addEventListener("scroll", updateCarouselControls, { passive: true });
        window.addEventListener("resize", updateCarouselControls);
        updateCarouselControls();
      });

      const markActiveSection = (id) => {
        sectionMapLinks.forEach((link) => {
          const isActive =
            link instanceof HTMLElement && link.dataset.sectionLink === id;
          link.classList.toggle("is-active", isActive);
        });
      };

      const markCurrentSection = () => {
        const activationPoint = window.scrollY + window.innerHeight * 0.22;
        let currentSection = pageSections[0];

        pageSections.forEach((section) => {
          if (
            section instanceof HTMLElement &&
            section.offsetTop <= activationPoint
          ) {
            currentSection = section;
          }
        });

        if (currentSection instanceof HTMLElement) {
          markActiveSection(currentSection.id);
        }
      };

      markCurrentSection();
      window.addEventListener("scroll", markCurrentSection, { passive: true });
      window.addEventListener("resize", markCurrentSection);
    </script>
  </body>
</html>

<style>
  :root {
    --background: #f7f3ec;
    --background-soft: #eef3f1;
    --text: #1b1f23;
    --muted: #4b5560;
    --accent: #2f6f62;
    --accent-strong: #1f5f53;
    --border: rgba(27, 31, 35, 0.14);
    --border-soft: rgba(27, 31, 35, 0.12);
    --surface-card: rgba(255, 255, 255, 0.62);
    --shadow: rgba(27, 31, 35, 0.14);
    color: var(--text);
    background: var(--background);
    color-scheme: light;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  :root[data-theme="dark"] {
    --background: #141715;
    --background-soft: #1d2421;
    --text: #f2f0ea;
    --muted: #b7c0ba;
    --accent: #80c9b5;
    --accent-strong: #a4decd;
    --border: rgba(242, 240, 234, 0.18);
    --border-soft: rgba(242, 240, 234, 0.12);
    --surface-card: rgba(255, 255, 255, 0.07);
    --shadow: rgba(0, 0, 0, 0.3);
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--background) 96%, transparent),
        color-mix(in srgb, var(--background-soft) 96%, transparent)
      ),
      var(--background);
  }

  html {
    scroll-behavior: smooth;
  }

  .site-shell {
    width: min(100% - 32px, 960px);
    margin: 0 auto;
    padding: 36px 0 72px;
  }

  .page-controls {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100vw;
    min-height: 44px;
    margin-left: calc(50% - 50vw);
    margin-bottom: 32px;
    padding: 2px max(16px, calc((100vw - 960px) / 2)) 12px;
    border-bottom: 1px solid var(--border-soft);
    background: var(--background);
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    padding: 0;
  }

  .section-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(78vw, 280px);
    padding: 72px 24px 32px;
    border-right: 1px solid var(--border);
    background: var(--background);
    box-shadow: 18px 0 42px var(--shadow);
    transform: translateX(-105%);
    transition: transform 180ms ease;
  }

  .section-sidebar.is-open {
    transform: translateX(0);
  }

  .drawer-controls {
    position: absolute;
    top: 24px;
    left: 0;
    right: 15px;
    height: 24px;
  }

  .drawer-controls .theme-toggle {
    position: absolute;
    left: 15px;
  }

  .drawer-controls .home-link {
    position: absolute;
    right: 0;
  }

  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 35;
    border: 0;
    background: rgba(0, 0, 0, 0.28);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .nav-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .section-sidebar [data-section-link] {
    position: relative;
    display: block;
    padding-top: 22px;
    padding-bottom: 22px;
    padding-left: 22px;
    color: color-mix(in srgb, var(--muted) 78%, transparent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .section-sidebar [data-section-link]::before {
    position: absolute;
    top: 50%;
    left: 0;
    z-index: 1;
    width: 7px;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    background: var(--background);
    content: "";
    transform: translateY(-50%);
  }

  .section-sidebar::before {
    position: absolute;
    top: 72px;
    bottom: 72px;
    left: 27px;
    width: 1px;
    background: color-mix(in srgb, var(--border) 72%, transparent);
    content: "";
  }

  .section-sidebar [data-section-link]:hover,
  .section-sidebar [data-section-link].is-active {
    color: var(--accent-strong);
  }

  .section-sidebar [data-section-link].is-active::before {
    background: currentColor;
  }

  .page-control-links {
    display: none;
    align-items: center;
    gap: 14px;
  }
  .home-link,
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    padding: 0;
  }
  .nav-toggle-icon,
  .home-link-icon,
  .theme-toggle-icon {
    width: 24px;
    aspect-ratio: 1;
    display: block;
  }
  :root[data-theme="dark"] .nav-toggle-icon,
  :root[data-theme="dark"] .home-link-icon,
  :root[data-theme="dark"] .theme-toggle-icon {
    filter: invert(1);
  }

  @media (min-width: 1380px) {
    .page-controls {
      position: fixed;
      top: 36px;
      right: clamp(36px, 4vw, 72px);
      z-index: 20;
      width: auto;
      min-height: 0;
      justify-content: flex-end;
      margin-left: 0;
      margin-bottom: 0;
      padding: 0;
      border-bottom: 0;
      background: transparent;
    }

    .desktop-controls {
      display: flex;
    }

    .drawer-controls {
      display: none;
    }

    .nav-toggle,
    .nav-backdrop {
      display: none;
    }

    .section-sidebar {
      position: fixed;
      top: 50%;
      left: max(24px, calc((100vw - 960px) / 2 - 220px));
      z-index: 10;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 172px;
      min-height: min(560px, 72vh);
      padding: 0;
      border-right: 0;
      background: transparent;
      box-shadow: none;
      transform: translateY(-50%);
    }

    .section-sidebar [data-section-link] {
      padding-top: 0;
      padding-bottom: 0;
    }

    .section-sidebar::before {
      position: absolute;
      top: 0.4em;
      bottom: 0.4em;
      left: 3px;
      width: 1px;
      background: color-mix(in srgb, var(--border) 72%, transparent);
      content: "";
    }

    .section-sidebar [data-section-link]::before {
      top: 0.4em;
      transform: none;
    }
  }

  .certificate-hero {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    align-items: center;
    gap: 28px;
    padding: 10px 0 48px;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 28px;
  }

  .certificate-icon {
    width: 160px;
    aspect-ratio: 1;
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 18px 48px var(--shadow);
    object-fit: cover;
    transform: translateY(-12px);
  }

  .certificate-overview {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    align-items: center;
    gap: 28px;
    margin-bottom: 28px;
  }

  .certificate-overview .certificate-icon {
    transform: none;
  }

  .certificate-overview h2 {
    margin-bottom: 12px;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
    text-transform: none;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .certificate-copy {
    text-align: left;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 14px;
    font-size: clamp(2.7rem, 7vw, 5.3rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 20px;
    font-size: 1rem;
    text-transform: uppercase;
  }

  h3 {
    margin-bottom: 14px;
    font-size: 1.2rem;
  }

  .intro {
    max-width: 660px;
