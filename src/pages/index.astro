---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Personal website for resume, projects, and contact links."
    />
    <title>
      Ben Correll
    </title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        savedTheme ?? (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <nav class="section-sidebar" aria-label="Page sections">
      {
        sectionLinks.map((link) => (
          <a href={link.href} data-section-link={link.href.slice(1)}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <main class="site-shell">
      <header class="hero" id="profile">
        <div class="hero-heading">
          <div class="portrait-frame">
            <div class="portrait-header">
              <!--
                Theme icons created by dokodemo - Flaticon
                https://www.flaticon.com/free-icons/theme
              -->
              <button
                class="theme-toggle"
                type="button"
                aria-label="Switch to dark mode"
                title="To Dark Mode"
              >
                <img
                  class="theme-toggle-icon"
                  src="/icons/dark-to-light.png"
                  alt=""
                  aria-hidden="true"
                />
              </button>
            </div>
            <img
              class="portrait"
              src="/me.jpeg"
              alt="Ben Correll"
            />
          </div>
          <div class="headline">
            <h1>
              Ben Correll
            </h1>
            <p class="subtitle">
              <span>
                Application Engineer @
              </span>
              <span class="subtitle-company">
                <img
                  class="subtitle-company-icon"
                  src="/resume-icons/capitalone.jpeg"
                  alt=""
                  aria-hidden="true"
                />
                Capital One
              </span>
            </p>
          </div>
        </div>
        <p class="intro">
          Senior Software Engineer with experience in modernizing enterprise financial
          platforms using Java, Python, and AWS.
        </p>
        <nav class="actions" aria-label="Primary links">
          <a
            class="button primary"
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Resume
          </a>
          <a
            class="button"
            href="https://github.com/bcorrel2"
            target="_blank"
            rel="noopener noreferrer"
            title="To GitHub"
          >
            See Projects
          </a>
        </nav>
      </header>

      <section class="section" id="work" aria-labelledby="work-heading">
        <h2 id="work-heading">
          Work Experience
        </h2>
        <div class="resume-list">
          {
            workExperience.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon"
                  src={item.icon}
                  alt={`${item.company} logo`}
                />
                <div>
                  <h3>
                    {item.role}
                  </h3>
                  <p class="resume-organization">
                    {item.company}
                  </p>
                  {
                    item.context && (
                      <p>
                        {item.context}
                      </p>
                    )
                  }
                  <p class="resume-years">
                    {item.years}
                  </p>
                  <p>
                    {item.location}
                  </p>
                  {item.acquisition && (
                    <div class="resume-note">
                      <img
                        src={item.acquisition.icon}
                        alt=""
                      />
                      <span>
                        {item.acquisition.label}
                      </span>
                    </div>
                  )}
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a href={link.href}>
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="education" aria-labelledby="education-heading">
        <h2 id="education-heading">
          Education
        </h2>
        <div class="resume-list">
          {
            education.map((item) => (
              <article
                class:list={["resume-item", item.href && "resume-item-link"]}
                data-href={item.href || undefined}
                role={item.href ? "link" : undefined}
                tabindex={item.href ? "0" : undefined}
              >
                <img
                  class="resume-icon"
                  src={item.icon}
                  alt={`${item.school} logo`}
                />
                <div>
                  <h3>
                    {item.school}
                  </h3>
                  <p>
                    {item.details}
                  </p>
                  <p class="resume-years">
                    {item.years}
                  </p>
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a href={link.href}>
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-heading">
        <h2 id="projects-heading">
          Projects
        </h2>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <h3>
                  {project.title}
                </h3>
                {
                  project.description && (
                    <p>
                      {project.description}
                    </p>
                  )
                }
                <div class="project-actions">
                  {
                    project.disabled ? (
                      <button class="project-action" type="button" disabled>
                        Open
                      </button>
                    ) : (
                      <a
                        class="project-action"
                        href={project.href}
                        target={project.href.startsWith("http") ? "_blank" : undefined}
                        rel={project.href.startsWith("http") ? "noopener noreferrer" : undefined}
                      >
                        Open
                      </a>
                    )
                  }
                  {
                    project.playDisabled && (
                      <button
                        class="project-action"
                        type="button"
                        title="Coming Soon"
                        disabled
                      >
                        Play
                      </button>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section
        class="section"
        id="certifications"
        aria-labelledby="certifications-heading"
      >
        <h2 id="certifications-heading">
          Certifications
        </h2>
        <div class="resume-list">
          {
            certifications.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon certification-icon"
                  src={item.icon}
                  alt={`${item.issuer} logo`}
                />
                <div>
                  <h3>
                    {item.title}
                  </h3>
                  <p class="resume-organization">
                    {item.issuer}
                  </p>
                  <p class="resume-years">
                    {item.note}
                  </p>
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a href={link.href}>
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="honors" aria-labelledby="honors-heading">
        <h2 id="honors-heading">
          Honors and Awards
        </h2>
        <div class="resume-list">
          {
            honorsAndAwards.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon transparent-icon"
                  src={item.icon}
                  alt={`${item.title} logo`}
                />
                <div>
                  <h3>
                    {item.title}
                  </h3>
                  <p class="resume-organization">
                    {item.organization}
                  </p>
                  <p class="resume-years">
                    {item.date}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="links" aria-labelledby="links-heading">
        <h2 id="links-heading">
          Links
        </h2>
        <div class="link-list">
          {
            links.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </section>

      <footer class="legal-disclaimer">
        <p>
          This site is a personal portfolio. Company, school, certification, and
          award names, logos, and marks are the property of their respective
          owners and are used for identification purposes only. This site is not
          endorsed by, sponsored by, or affiliated with those organizations.
        </p>
      </footer>
    </main>
    <script>
      /** @typedef {"light" | "dark"} Theme */

      /** @type {HTMLButtonElement | null} */
      const themeToggle = document.querySelector(".theme-toggle");
      /** @type {HTMLImageElement | null} */
      const themeToggleIcon = document.querySelector(".theme-toggle-icon");
      const resumeItemLinks = document.querySelectorAll(".resume-item-link");
      const sections = document.querySelectorAll(".hero[id], .section[id]");
      const sectionLinks = document.querySelectorAll("[data-section-link]");

      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

      /**
       * @param {Theme} theme
       * @param {boolean} persist
       */
      const setTheme = (theme, persist = true) => {
        document.documentElement.dataset.theme = theme;
        if (persist) {
          localStorage.setItem("theme", theme);
        }

        if (themeToggle) {
          themeToggle.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light mode" : "Switch to dark mode",
          );
          themeToggle.setAttribute(
            "title",
            theme === "dark" ? "Light Mode" : "Dark Mode",
          );
        }

        if (themeToggleIcon) {
          themeToggleIcon.src =
            theme === "dark" ? "/icons/dark-to-light.png" : "/icons/dark-to-light.png";
        }
      };

      const currentTheme =
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setTheme(currentTheme, false);

      systemTheme.addEventListener("change", (event) => {
        if (!localStorage.getItem("theme")) {
          setTheme(event.matches ? "dark" : "light", false);
        }
      });

      themeToggle?.addEventListener("click", () => {
        setTheme(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
      });

      resumeItemLinks.forEach((item) => {
        item.addEventListener("click", (event) => {
          if (event.target instanceof Element && event.target.closest("a, button")) {
            return;
          }

          if (item instanceof HTMLElement && item.dataset.href) {
            window.location.href = item.dataset.href;
          }
        });

        item.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") {
            return;
          }

          if (item instanceof HTMLElement && item.dataset.href) {
            event.preventDefault();
            window.location.href = item.dataset.href;
          }
        });
      });

      const markActiveSection = (id) => {
        sectionLinks.forEach((link) => {
          const isActive =
            link instanceof HTMLElement && link.dataset.sectionLink === id;
          link.classList.toggle("is-active", isActive);
        });
      };

      const markCurrentSection = () => {
        const activationPoint = window.scrollY + window.innerHeight * 0.38;
        let currentSection = sections[0];

        sections.forEach((section) => {
          if (
            section instanceof HTMLElement &&
            section.offsetTop <= activationPoint
          ) {
            currentSection = section;
          }
        });

        if (currentSection instanceof HTMLElement) {
          markActiveSection(currentSection.id);
        }
      };

      markCurrentSection();
      window.addEventListener("scroll", markCurrentSection, { passive: true });
      window.addEventListener("resize", markCurrentSection);
    </script>
  </body>
</html>

<style>
  :root {
    --background: #f7f3ec;
    --background-soft: #eef3f1;
    --text: #1b1f23;
    --muted: #4b5560;
    --accent: #2f6f62;
    --accent-strong: #1f5f53;
    --accent-hover: #123d36;
    --border: rgba(27, 31, 35, 0.14);
    --border-soft: rgba(27, 31, 35, 0.1);
    --surface: rgba(255, 255, 255, 0.64);
    --surface-card: rgba(255, 255, 255, 0.62);
    --shadow: rgba(27, 31, 35, 0.14);
    color: var(--text);
    background: var(--background);
    color-scheme: light;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  :root[data-theme="dark"] {
    --background: #141715;
    --background-soft: #1d2421;
    --text: #f2f0ea;
    --muted: #b7c0ba;
    --accent: #80c9b5;
    --accent-strong: #a4decd;
    --accent-hover: #d4fff2;
    --border: rgba(242, 240, 234, 0.18);
    --border-soft: rgba(242, 240, 234, 0.12);
    --surface: rgba(255, 255, 255, 0.08);
    --surface-card: rgba(255, 255, 255, 0.07);
    --shadow: rgba(0, 0, 0, 0.3);
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--background) 96%, transparent),
        color-mix(in srgb, var(--background-soft) 96%, transparent)
      ),
      var(--background);
  }

  a {
    color: inherit;
  }

  html {
    scroll-behavior: smooth;
  }

  .site-shell {
    width: min(100% - 32px, 960px);
    margin: 0 auto;
    padding: 36px 0 64px;
  }

  .hero {
    position: relative;
    padding: 24px 0 48px;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 28px;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 780px;
    margin-bottom: 0;
    font-size: clamp(3.2rem, 9vw, 6.8rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .headline {
    min-width: 0;
  }

  .subtitle {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin: 12px 0 0 4px;
    color: var(--muted);
    font-size: clamp(1.1rem, 2.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1.25;
  }

  .subtitle-company {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .subtitle-company-icon {
    width: 24px;
    aspect-ratio: 1;
    border: 1px solid var(--border);
    border-radius: 6px;
    object-fit: cover;
  }

  .hero-heading {
    display: grid;
    grid-template-columns: minmax(160px, 0.34fr) minmax(0, 1fr);
    align-items: center;
    gap: 24px;
    margin-bottom: 22px;
  }

  .portrait {
    width: 100%;
    max-width: 260px;
    aspect-ratio: 1;
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 18px 48px var(--shadow);
    object-fit: cover;
  }

  .portrait-frame {
    width: 100%;
    max-width: 260px;
  }

  .portrait-header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }

  h2 {
    margin-bottom: 18px;
    font-size: 1rem;
    text-transform: uppercase;
  }

  h3 {
    margin-bottom: 10px;
    font-size: 1.25rem;
  }

  .intro {
    max-width: 640px;
    color: var(--muted);
    font-size: clamp(1.15rem, 3vw, 1.45rem);
    line-height: 1.55;
  }

  .actions,
  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button,
  .link-list a,
  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
  }

  .project-action:disabled {
    cursor: not-allowed;
    opacity: 0.52;
  }

  .button.primary {
    border-color: var(--text);
    background: var(--text);
    color: var(--background);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    padding: 0;
  }

  .portrait-header .theme-toggle {
    position: absolute;
    top: 24px;
    right: 0;
  }

  .theme-toggle-icon {
    width: 24px;
    aspect-ratio: 1;
    display: block;
  }

  :root[data-theme="dark"] .theme-toggle-icon {
    filter: invert(1);
  }

  .section {
    padding: 42px 0;
    border-bottom: 1px solid var(--border-soft);
    scroll-margin-top: 28px;
  }

  .section-sidebar {
    display: none;
  }

  .section-sidebar a {
    position: relative;
    display: block;
    padding-left: 22px;
    color: color-mix(in srgb, var(--muted) 78%, transparent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .section-sidebar a::before {
    position: absolute;
    top: 0.4em;
    left: 0;
    z-index: 1;
    width: 7px;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    background: var(--background);
    content: "";
  }

  .section-sidebar a:hover,
  .section-sidebar a.is-active {
    color: var(--accent-strong);
  }

  .section-sidebar a.is-active::before {
    background: currentColor;
  }

  .legal-disclaimer {
    padding: 28px 0 56vh;
    color: color-mix(in srgb, var(--muted) 72%, transparent);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .legal-disclaimer p {
    max-width: 760px;
    margin-bottom: 0;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    min-height: 190px;
    padding: 22px;
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    background: var(--surface-card);
  }

  .project-card p {
    color: var(--muted);
    line-height: 1.55;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
  }

  .project-card .project-action {
    width: fit-content;
