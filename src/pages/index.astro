const education = [
  {
    school: "Purdue University",
    details: "Master of Business Administration (MBA), Daniels School of Business",
    years: "2025 - 2026 (Expected)",
    icon: "/resume-icons/purdue.jpeg",
    links: [
      { label: "Business & Technology", href: "#" },
      { label: "Business & Economic Data Analytics", href: "#" },
