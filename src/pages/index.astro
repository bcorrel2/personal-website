---

<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Personal website for resume, projects, and contact links."
    />
    <title>
      Ben Correll
    </title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        savedTheme ?? (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <nav class="section-sidebar" aria-label="Page sections">
      <div class="drawer-controls">
        <!--
          Theme icons created by dokodemo - Flaticon
          https://www.flaticon.com/free-icons/theme
        -->
        <button
          class="theme-toggle"
          type="button"
          aria-label="Switch to dark mode"
          title="To Dark Mode"
        >
          <img
            class="theme-toggle-icon"
            src="/icons/light-to-dark.png"
            alt=""
            aria-hidden="true"
          />
        </button>
      </div>
      {
        sectionLinks.map((link) => (
          <a href={link.href} data-section-link={link.href.slice(1)}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <button
      class="nav-backdrop"
      type="button"
      aria-label="Close section navigation"
    >
    </button>

    <main class="site-shell">
      <div class="mobile-top-bar">
        <button
          class="nav-toggle"
          type="button"
          aria-label="Open section navigation"
          aria-expanded="false"
        >
          <img
            class="nav-toggle-icon"
            src="/icons/list.png"
            alt=""
            aria-hidden="true"
          />
        </button>
      </div>

      <header class="hero" id="profile">
        <div class="hero-heading">
          <div class="portrait-frame">
            <div class="portrait-header">
              <!--
                Theme icons created by dokodemo - Flaticon
                https://www.flaticon.com/free-icons/theme
              -->
              <button
                class="theme-toggle desktop-theme-toggle"
                type="button"
                aria-label="Switch to dark mode"
                title="To Dark Mode"
              >
                <img
                  class="theme-toggle-icon"
                  src="/icons/light-to-dark.png"
                  alt=""
                  aria-hidden="true"
                />
              </button>
            </div>
            <img
              class="portrait"
              src="/me.jpeg"
              alt="Ben Correll"
            />
          </div>
          <div class="headline">
            <h1>
              Ben Correll
            </h1>
            <p class="subtitle">
              <span>
                Application Engineer <span class="subtitle-at">@</span>
              </span>
              <span class="subtitle-company">
                <img
                  class="subtitle-company-icon"
                  src="/resume-icons/capitalone.jpeg"
                  alt=""
                  aria-hidden="true"
                />
                Capital One
              </span>
            </p>
          </div>
        </div>
        <p class="intro">
          Senior Software Engineer with experience in modernizing enterprise financial
          platforms using Java, Python, and AWS.
        </p>
        <nav class="actions" aria-label="Primary links">
          <a
            class="button primary"
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Resume
          </a>
          <a
            class="button"
            href="https://github.com/bcorrel2"
            target="_blank"
            rel="noopener noreferrer"
            title="To GitHub"
          >
            See Projects
          </a>
        </nav>
      </header>

      <section class="section" id="work" aria-labelledby="work-heading">
        <h2 id="work-heading">
          Work Experience
        </h2>
        <div class="resume-list">
          {
            workExperience.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon"
                  src={item.icon}
                  alt={`${item.company} logo`}
                />
                <div>
                  <h3>
                    {item.role}
                  </h3>
                  <p class="resume-organization">
                    {item.company}
                  </p>
                  {
                    item.context && (
                      <p>
                        {item.context}
                      </p>
                    )
                  }
                  <p class="resume-years">
                    {item.years}
                  </p>
                  <p>
                    {item.location}
                  </p>
                  {item.acquisition && (
                    <div class="resume-note">
                      <img
                        src={item.acquisition.icon}
                        alt=""
                      />
                      <span>
                        <span class="resume-note-label-full">
                          {item.acquisition.label}
                        </span>
                        {
                          item.acquisition.shortLabel && (
                            <span class="resume-note-label-short">
                              {item.acquisition.shortLabel}
                            </span>
                          )
                        }
                      </span>
                    </div>
                  )}
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a
                          class:list={[link.shortLabel && "has-short-label"]}
                          href={link.href}
                        >
                          <span class="education-label-full">
                            {link.label}
                          </span>
                          {
                            link.shortLabel && (
                              <span class="education-label-short">
                                {link.shortLabel}
                              </span>
                            )
                          }
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="education" aria-labelledby="education-heading">
        <h2 id="education-heading">
          Education
        </h2>
        <div class="resume-list">
          {
            education.map((item) => (
              <article
                class:list={["resume-item", item.href && "resume-item-link"]}
                data-href={item.href || undefined}
                role={item.href ? "link" : undefined}
                tabindex={item.href ? "0" : undefined}
              >
                <img
                  class="resume-icon"
                  src={item.icon}
                  alt={`${item.school} logo`}
                />
                <div>
                  <h3>
                    {item.school}
                  </h3>
                  <p>
                    <span class="education-detail-full">
                      {item.details}
                    </span>
                    {
                      item.shortDetails && (
                        <span class="education-detail-short">
                          {item.shortDetails}
                        </span>
                      )
                    }
                  </p>
                  <p class="resume-years">
                    {item.years}
                  </p>
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a
                          class:list={[link.shortLabel && "has-short-label"]}
                          href={link.href}
                        >
                          <span class="education-label-full">
                            {link.label}
                          </span>
                          {
                            link.shortLabel && (
                              <span class="education-label-short">
                                {link.shortLabel}
                              </span>
                            )
                          }
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>
      <section class="section" id="links" aria-labelledby="links-heading">
        <h2 id="links-heading">
          Links
        </h2>
        <div class="link-list">
          {
            links.map((link) =>
              link.disabled ? (
                <button type="button" title={link.title} disabled>
                  {link.label}
                </button>
              ) : (
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ),
            )
          }
        </div>
      </section>

      <section
        class="section"
        id="certifications"
        aria-labelledby="certifications-heading"
      >
        <h2 id="certifications-heading">
          Certifications
        </h2>
        <div class="resume-list">
          {
            certifications.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon certification-icon"
                  src={item.icon}
                  alt={`${item.issuer} logo`}
                />
                <div>
                  <h3>
                    {item.title}
                  </h3>
                  <p class="resume-organization">
                    {item.issuer}
                  </p>
                  <p class="resume-years">
                    {item.note}
                  </p>
                  {item.links.length > 0 && (
                    <div class="education-links">
                      {item.links.map((link) => (
                        <a
                          class:list={[link.shortLabel && "has-short-label"]}
                          href={link.href}
                        >
                          <span class="education-label-full">
                            {link.label}
                          </span>
                          {
                            link.shortLabel && (
                              <span class="education-label-short">
                                {link.shortLabel}
                              </span>
                            )
                          }
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>


      <section class="section" id="projects" aria-labelledby="projects-heading">
        <h2 id="projects-heading">
          Projects
        </h2>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <h3>
                  {project.title}
                </h3>
                {
                  project.description && (
                    <p>
                      {project.description}
                    </p>
                  )
                }
                <div class="project-actions">
                  {
                    project.disabled ? (
                      <button class="project-action" type="button" disabled>
                        Open
                      </button>
                    ) : (
                      <a
                        class="project-action"
                        href={project.href}
                        target={project.href.startsWith("http") ? "_blank" : undefined}
                        rel={project.href.startsWith("http") ? "noopener noreferrer" : undefined}
                      >
                        Open
                      </a>
                    )
                  }
                  {
                    project.playDisabled && (
                      <button
                        class="project-action"
                        type="button"
                        title="Coming Soon"
                        disabled
                      >
                        Play
                      </button>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>
      <section
        class="section final-section"
        id="honors"
        aria-labelledby="honors-heading"
      >
        <h2 id="honors-heading">
          Honors and Awards
        </h2>
        <div class="resume-list">
          {
            honorsAndAwards.map((item) => (
              <article class="resume-item">
                <img
                  class="resume-icon transparent-icon"
                  src={item.icon}
                  alt={`${item.title} logo`}
                />
                <div>
                  <h3>
                    {item.title}
                  </h3>
                  <p class="resume-organization">
                    {item.organization}
                  </p>
                  <p class="resume-years">
                    {item.date}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
        <div class="section-action">
          <a
            class="top-link"
            href="#profile"
            aria-label="Go to top of page"
            title="Top"
          >
            Top of Page
          </a>
        </div>
      </section>

      <footer
        class="section legal-disclaimer"
        id="legal"
        aria-label="Legal disclaimer"
      >
        <p>
          This site is a personal portfolio. Company, school, certification, and
          award names, logos, and marks are the property of their respective
          owners and are used for identification purposes only. This site is not
          endorsed by, sponsored by, or affiliated with those organizations.
        </p>
      </footer>
    </main>
    <script>
      /** @typedef {"light" | "dark"} Theme */

      const themeToggles = document.querySelectorAll(".theme-toggle");
      const themeToggleIcons = document.querySelectorAll(".theme-toggle-icon");
      const navToggle = document.querySelector(".nav-toggle");
      const sectionSidebar = document.querySelector(".section-sidebar");
      const navBackdrop = document.querySelector(".nav-backdrop");
      const resumeItemLinks = document.querySelectorAll(".resume-item-link");
      const sections = document.querySelectorAll(".hero[id], .section[id]");
      const sectionLinks = document.querySelectorAll("[data-section-link]");

      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

      /**
       * @param {Theme} theme
       * @param {boolean} persist
       */
      const setTheme = (theme, persist = true) => {
        document.documentElement.dataset.theme = theme;
        if (persist) {
          localStorage.setItem("theme", theme);
        }

        themeToggles.forEach((themeToggle) => {
          themeToggle.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light mode" : "Switch to dark mode",
          );
          themeToggle.setAttribute(
            "title",
            theme === "dark" ? "Light Mode" : "Dark Mode",
          );
        });

        themeToggleIcons.forEach((themeToggleIcon) => {
          themeToggleIcon.src =
            theme === "dark" ? "/icons/dark-to-light.png" : "/icons/light-to-dark.png";
        });
      };

      const currentTheme =
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setTheme(currentTheme, false);

      systemTheme.addEventListener("change", (event) => {
        if (!localStorage.getItem("theme")) {
          setTheme(event.matches ? "dark" : "light", false);
        }
      });

      themeToggles.forEach((themeToggle) => {
        themeToggle.addEventListener("click", () => {
          setTheme(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
        });
      });

      const closeSectionNavigation = () => {
        sectionSidebar?.classList.remove("is-open");
        navBackdrop?.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      };

      navToggle?.addEventListener("click", () => {
        const isOpen = !sectionSidebar?.classList.contains("is-open");
        sectionSidebar?.classList.toggle("is-open", isOpen);
        navBackdrop?.classList.toggle("is-open", isOpen);
        navToggle.setAttribute("aria-expanded", String(isOpen));
      });

      navBackdrop?.addEventListener("click", closeSectionNavigation);

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSectionNavigation();
        }
      });

      resumeItemLinks.forEach((item) => {
        item.addEventListener("click", (event) => {
          if (event.target instanceof Element && event.target.closest("a, button")) {
            return;
          }

          if (item instanceof HTMLElement && item.dataset.href) {
            window.location.href = item.dataset.href;
          }
        });

        item.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") {
            return;
          }

          if (item instanceof HTMLElement && item.dataset.href) {
            event.preventDefault();
            window.location.href = item.dataset.href;
          }
        });
      });

      const mobileView = window.matchMedia("(max-width: 680px)");
      const projectGrid = document.querySelector(".project-grid");

      if (
        mobileView.matches &&
        projectGrid instanceof HTMLElement &&
        !projectGrid.nextElementSibling?.classList.contains("carousel-scrubber")
      ) {
        const projectCards = Array.from(
          projectGrid.querySelectorAll(".project-card"),
        );

        if (projectCards.length > 1) {
          const scrubber = document.createElement("div");
          scrubber.className = "carousel-scrubber";
          scrubber.setAttribute("aria-hidden", "true");

          const scrubberThumb = document.createElement("button");
          scrubberThumb.type = "button";
          scrubber.append(scrubberThumb);

          const updateProjectScrubber = () => {
            const maxScroll = projectGrid.scrollWidth - projectGrid.clientWidth;
            const scrubberWidth = scrubber.clientWidth;
            const thumbWidth = Math.max(
              28,
              (projectGrid.clientWidth / projectGrid.scrollWidth) * scrubberWidth,
            );
            const maxThumbOffset = scrubberWidth - thumbWidth;
            const progress = maxScroll > 0 ? projectGrid.scrollLeft / maxScroll : 0;

            scrubberThumb.style.width = `${thumbWidth}px`;
            scrubberThumb.style.transform = `translateX(${progress * maxThumbOffset}px)`;
          };

          let isProjectDragging = false;
          let projectDragStartX = 0;
          let projectDragStartScroll = 0;

          projectGrid.addEventListener("pointerdown", (event) => {
            if (event.pointerType === "mouse" && event.button !== 0) {
              return;
            }

            isProjectDragging = true;
            projectDragStartX = event.clientX;
            projectDragStartScroll = projectGrid.scrollLeft;
            projectGrid.classList.add("is-dragging");
            projectGrid.setPointerCapture(event.pointerId);
          });

          projectGrid.addEventListener("pointermove", (event) => {
            if (!isProjectDragging) {
              return;
            }

            projectGrid.scrollLeft =
              projectDragStartScroll - (event.clientX - projectDragStartX);
          });

          const stopProjectDrag = (event) => {
            isProjectDragging = false;
            projectGrid.classList.remove("is-dragging");
            if (projectGrid.hasPointerCapture(event.pointerId)) {
              projectGrid.releasePointerCapture(event.pointerId);
            }
          };

          projectGrid.addEventListener("pointerup", stopProjectDrag);
          projectGrid.addEventListener("pointercancel", stopProjectDrag);

          let isScrubberDragging = false;

          const moveScrubber = (event) => {
            const rect = scrubber.getBoundingClientRect();
            const progress = Math.min(
              1,
              Math.max(0, (event.clientX - rect.left) / rect.width),
            );

            projectGrid.scrollLeft =
              progress * (projectGrid.scrollWidth - projectGrid.clientWidth);
          };

          scrubber.addEventListener("pointerdown", (event) => {
            isScrubberDragging = true;
            scrubber.setPointerCapture(event.pointerId);
            moveScrubber(event);
          });

          scrubber.addEventListener("pointermove", (event) => {
            if (isScrubberDragging) {
              moveScrubber(event);
            }
          });

          scrubber.addEventListener("pointerup", (event) => {
            isScrubberDragging = false;
            if (scrubber.hasPointerCapture(event.pointerId)) {
              scrubber.releasePointerCapture(event.pointerId);
            }
          });

          projectGrid.after(scrubber);
          projectGrid.addEventListener("scroll", updateProjectScrubber, {
            passive: true,
          });
          window.addEventListener("resize", updateProjectScrubber);
          updateProjectScrubber();
        }
      }

      const markActiveSection = (id) => {
        sectionLinks.forEach((link) => {
          const isActive =
            link instanceof HTMLElement && link.dataset.sectionLink === id;
          link.classList.toggle("is-active", isActive);
        });
      };

      const markCurrentSection = () => {
        const activationPoint = window.scrollY + window.innerHeight * 0.38;
        let currentSection = sections[0];

        sections.forEach((section) => {
          if (
            section instanceof HTMLElement &&
            section.offsetTop <= activationPoint
          ) {
            currentSection = section;
          }
        });

        if (currentSection instanceof HTMLElement) {
          markActiveSection(currentSection.id);
        }
      };

      markCurrentSection();
      window.addEventListener("scroll", markCurrentSection, { passive: true });
      window.addEventListener("resize", markCurrentSection);
    </script>
  </body>
</html>

<style>
  :root {
    --background: #f7f3ec;
    --background-soft: #eef3f1;
    --text: #1b1f23;
    --muted: #4b5560;
    --accent: #2f6f62;
    --accent-strong: #1f5f53;
    --accent-hover: #123d36;
    --border: rgba(27, 31, 35, 0.14);
    --border-soft: rgba(27, 31, 35, 0.1);
    --surface: rgba(255, 255, 255, 0.64);
    --surface-card: rgba(255, 255, 255, 0.62);
    --shadow: rgba(27, 31, 35, 0.14);
    color: var(--text);
    background: var(--background);
    color-scheme: light;
    font-family:
      Inter,
